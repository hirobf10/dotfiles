      "~/.claude",
      "~/.local/share/chezmoi"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-agent-state.sh session",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/herdr-tab-title.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": true,
    "terraform-module-generation@hashicorp": true,
    "terraform-provider-development@hashicorp": true
  },
  "extraKnownMarketplaces": {
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "theme": "dark",
  "verbose": true,
  "remoteControlAtStartup": true,
  "voiceEnabled": true
}
