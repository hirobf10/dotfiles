{{- $email := promptStringOnce . "email" "Git email address" -}}
{{- $name := promptStringOnce . "name" "Git user name" -}}
{{- $environment := promptChoiceOnce . "environment" "Environment" (list "work" "personal") -}}

[data]
    email = "{{ $email }}"
    name = "{{ $name }}"
    environment = "{{ $environment }}"

[git]
    autoCommit = true
    autoPush = true
